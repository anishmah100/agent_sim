# Frontend env — copy to .env.local for local dev.
#
# The Vite dev server proxies nothing — these are read at build time
# (import.meta.env.*) and baked into the bundle.

# Where the engine lives. Local dev defaults to the local start.sh port.
# In production, point this at your deployed engine domain.
VITE_ENGINE_URL=http://127.0.0.1:8080
