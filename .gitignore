# ── Build outputs ────────────────────────────────────────────────────
node_modules/
dist/
build/
*.o
*.so
vendor/

# Go binaries (rebuilt by `./agent_sim start`)
engine/engine
engine/genart_manifest
engine/jsonl2sqlite
engine/genworld_pretty
engine/cmd/*/main.test

# ── Python ───────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo

# ── Editor / IDE ─────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*~

# ── Env / secrets ────────────────────────────────────────────────────
.env
.env.local
*.pem
*.key

# ── OS junk ──────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Logs / runtime ───────────────────────────────────────────────────
*.log
/tmp/
/data/
*.sqlite
*.sqlite-journal

# ── Local run artifacts from ./agent_sim ─────────────────────────────
.runlog/

# ── Art — raw generations + intermediates + legacy archive ──────────
# Each world bundle owns its art under worlds/<bundle>/art/. Only
# commit approved manifests/, processed/, and style.json. Raw
# generations, rejects, and legacy archives stay local.
worlds/*/art/raw/
worlds/*/art/rejected/
worlds/*/art/_legacy/
worlds/*/art/__pycache__/

# ── World runtime ────────────────────────────────────────────────────
worlds/snapshots/*.bin
# Live editor scratch — re-applied on every engine boot via the
# tile-edits overlay; shouldn't pollute git history.
worlds/*/tile_edits.json
worlds/*/decoration_edits.json

# ── Claude Code session metadata ─────────────────────────────────────
.claude/
