# ── Build outputs ────────────────────────────────────────────────────
node_modules/
dist/
build/
*.o
*.so
vendor/

# Go binaries (rebuilt by `./agent_sim start`)
engine/engine
engine/genart_manifest
engine/jsonl2sqlite
engine/genworld_pretty
engine/cmd/*/main.test

# ── Python ───────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo

# ── Editor / IDE ─────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*~

# ── Env / secrets ────────────────────────────────────────────────────
.env
.env.local
*.pem
*.key

# ── OS junk ──────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Logs / runtime ───────────────────────────────────────────────────
*.log
/tmp/
/data/
*.sqlite
*.sqlite-journal

# ── Local run artifacts from ./agent_sim ─────────────────────────────
.runlog/

# ── Art — raw generations + intermediates + legacy archive ──────────
# Only commit approved processed sprites + manifests. The art/
# directory should never grow beyond the current footprint of:
#   art/manifests/   ← sprite catalog + per-sheet manifests
#   art/processed/   ← derived sprites the renderer loads
#   art/style.json   ← global style anchor
art/raw/
art/rejected/
art/_legacy/
art/__pycache__/

# ── World runtime ────────────────────────────────────────────────────
worlds/snapshots/*.bin
# Live editor scratch — re-applied on every engine boot via the
# tile-edits overlay; shouldn't pollute git history.
worlds/*/tile_edits.json

# ── Claude Code session metadata ─────────────────────────────────────
.claude/
